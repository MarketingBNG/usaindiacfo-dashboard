# ──────────────────────────────────────────────────────────────
#  USA India CFO API — Environment Variables
#  Copy this file to .env and fill in the values.
#  Never commit .env to git.
# ──────────────────────────────────────────────────────────────

# App
PORT=3001
NODE_ENV=production

# Your Railway backend domain (no trailing slash)
BACKEND_URL=https://your-app.up.railway.app

# Your GitHub Pages frontend URL
FRONTEND_URL=https://marketingbng.github.io/usaindiacfo-dashboard
ALLOWED_ORIGINS=https://marketingbng.github.io

# Database — Railway provides this automatically as ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Meta (Facebook · Instagram · Meta Ads) ─────────────────────
# Create app at: https://developers.facebook.com/apps
# Required permissions: pages_show_list, pages_read_engagement,
#   instagram_basic, instagram_manage_insights, ads_read
META_APP_ID=
META_APP_SECRET=

# ── Google (Search Console · Google Ads) ───────────────────────
# Create OAuth client at: https://console.cloud.google.com/apis/credentials
# Enable: Search Console API, Google Ads API
# Redirect URI to add: ${BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Ads (additional setup required)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── LinkedIn (Pages · Ads) ──────────────────────────────────────
# Create app at: https://www.linkedin.com/developers/apps
# Required scopes: r_organization_social, r_ads, r_ads_reporting
# Redirect URI to add: ${BACKEND_URL}/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Your LinkedIn Page numeric ID (visible in the Page Admin URL)
LINKEDIN_ORG_ID=

# ── X / Twitter ─────────────────────────────────────────────────
# Requires Basic tier ($100/mo): https://developer.twitter.com
# Create project + app, enable OAuth 2.0, set redirect URI
# Redirect URI to add: ${BACKEND_URL}/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Reddit ──────────────────────────────────────────────────────
# Create app at: https://www.reddit.com/prefs/apps (type: web app)
# Redirect URI to add: ${BACKEND_URL}/auth/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
